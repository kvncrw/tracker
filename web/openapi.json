      "post": {
        "description": "Refresh positions for an account. Writes to DB + emits outbox events.\n\nRequires DATABASE_URL to be configured. If using FakeBroker without\nDB, this returns 503 (the use case needs persistence).",
        "operationId": "refresh_portfolio__account_id__refresh_post",
        "parameters": [
          {
            "in": "path",
            "name": "account_id",
            "required": true,
            "schema": {
