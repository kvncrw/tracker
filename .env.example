# Tracker environment. Copy to .env and fill in. .env is gitignored.

# --- App ---
APP_ENV=dev
LOG_LEVEL=INFO
BROKER_MODE=fake              # fake | schwab
ALLOW_LIVE_TRADING=false      # always false in v1 — no execution context

# --- Postgres ---
DATABASE_URL=postgresql+psycopg://tracker:tracker@localhost:5432/tracker

# --- Garage (S3-compatible blob store) ---
S3_ENDPOINT_URL=http://localhost:3900
S3_BUCKET=tracker-blobs
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Schwab (read-only until Execution context is built) ---
SCHWAB_CLIENT_ID=
SCHWAB_CLIENT_SECRET=
SCHWAB_REDIRECT_URI=http://localhost:8000/schwab/callback

# --- Market data ---
MASSIVE_API_KEY=              # né Polygon — verify actual hostname before deploy

# --- Congressional data ---
QUIVER_API_KEY=

# --- LLM for briefings (pick one; reuse aria plumbing if it fits) ---
LLM_PROVIDER=                 # anthropic | openai | local
LLM_API_KEY=
LLM_MODEL=

# --- Notifications ---
PUSH_PROVIDER=                # ntfy | pushover | apns
PUSH_TOKEN=
